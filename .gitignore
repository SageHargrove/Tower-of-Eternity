# Environment
backend/.env
backend/game.db

# Portraits (large files, regenerated locally)
backend/static/portraits/

# Python
__pycache__/
*.pyc
venv/
backend/venv/

# Node
frontend/node_modules/

# Audio WAV masters (~700MB source-of-truth; the shipped, playable OGGs live in
# frontend/public/audio/ and ARE committed — regenerate OGGs from masters with
# frontend/scripts/encode_audio.mjs). Masters themselves are too large for git.
audio_masters/

# pywebview's Edge WebView2 runtime profile/cache — regenerated on launch
webview_data/

# ComfyUI
ComfyUI/
*.mp3

# PyInstaller build artifacts (the packaged .exe is large/binary and fully
# regenerable from app_launcher.py + InfiniteGacha.spec — rebuild locally
# with `pyinstaller InfiniteGacha.spec` instead of committing it;
# frontend/dist/ stays tracked since the packaged exe needs it present)
/build/
/dist/
*.exe
/build_venv/

# Player save data + local DB backups — personal state, never committed
backend/saves/
backend/db_backups/

# Arena server runtime state (accounts/tokens/match history + its own
# per-profile snapshots) — regenerated by the server, never committed
arena_server/arena.db
arena_server/saves/

# Local agent/tooling state
.agent/
.claude/
